generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReviewDecision {
  APPROVED
  REVISION
}

enum CalendarEventType {
  MEETING
  COMPANY_EVENT
  TRAINING
  HOLIDAY
  DIRECTOR_SCHEDULE
  ANNOUNCEMENT
}

// ============================================================
// MODELS
// ============================================================

model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  role     UserRole @default(EMPLOYEE)
  isActive Boolean  @default(true)

  // Relasi ke Department (nullable: user bisa belum ditempatkan)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  // Tasks yang di-assign ke user ini
  assignedTasks Task[] @relation("TaskAssignee")

  // Tasks yang dibuat oleh user ini
  createdTasks Task[] @relation("TaskCreator")

  comments      TaskComment[]
  notifications Notification[]

  uploadedEvidences TaskEvidence[]
  workLogs          WorkLog[]
  reviews           TaskReview[]
  workSessions      WorkSession[]

  createdMeetings      Meeting[]            @relation("MeetingCreator")
  meetingParticipations MeetingParticipant[]

  createdCalendarEvents CalendarEvent[] @relation("CalendarEventCreator")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([departmentId])
}

model Department {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  users User[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?

  // User yang di-assign ke task (nullable: task bisa belum di-assign)
  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  // User yang membuat task (wajib)
  creatorId String
  creator   User   @relation("TaskCreator", fields: [creatorId], references: [id])

  // Work Evidence (Modul 5.0)
  completionNote String?
  completedAt    DateTime?

  // Manager Review (Modul 5.2)
  submittedForReviewAt DateTime?

  comments  TaskComment[]
  evidences TaskEvidence[]
  workLogs  WorkLog[]
  reviews   TaskReview[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([assigneeId])
  @@index([creatorId])
  @@index([status])
}

model TaskEvidence {
  id     String @id @default(uuid())
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  fileName    String
  fileUrl     String
  fileType    String
  fileSize    Int
  description String?

  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([uploadedById])
}

model WorkLog {
  id     String @id @default(uuid())
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  activity String
  progress Int?
  blocker  String?

  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([userId])
}

model Meeting {
  id          String  @id @default(uuid())
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  meetingUrl  String?

  createdById String
  createdBy   User   @relation("MeetingCreator", fields: [createdById], references: [id])

  participants MeetingParticipant[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([createdById])
  @@index([startAt])
}

model MeetingParticipant {
  id        String @id @default(uuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

// Corporate Calendar (Modul 6.2). Meeting (6.1) TIDAK disalin ke sini —
// CalendarEvent hanya menyimpan event non-meeting; timeline gabungan
// (Meeting + CalendarEvent) dirakit di calendar.service saat query.
model CalendarEvent {
  id          String            @id @default(uuid())
  title       String
  description String?
  type        CalendarEventType

  startAt DateTime
  endAt   DateTime

  createdById String
  createdBy   User   @relation("CalendarEventCreator", fields: [createdById], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([createdById])
  @@index([startAt])
  @@index([type])
}

model WorkSession {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  startedAt       DateTime
  endedAt         DateTime?
  durationMinutes Int?

  createdAt DateTime @default(now())

  @@index([userId])
}

model TaskReview {
  id     String @id @default(uuid())
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  reviewerId String
  reviewer   User   @relation(fields: [reviewerId], references: [id])

  decision ReviewDecision
  note     String

  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([reviewerId])
}

model TaskComment {
  id      String @id @default(uuid())
  content String

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([taskId])
  @@index([authorId])
}

model Notification {
  id      String  @id @default(uuid())
  title   String
  message String
  isRead  Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([userId, isRead])
}
